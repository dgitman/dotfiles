{
  "mcpServers": {
    "bigquery": {
      "authProviderType": "google_credentials",
      "serverUrl": "https://bigquery.googleapis.com/mcp"
    },
    "datacloud_alloydb_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://alloydb.us-east1.rep.googleapis.com/mcp"
    },
    "datacloud_bigquery_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://bigquery.googleapis.com/mcp"
    },
    "datacloud_cloud-sql_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://sqladmin.googleapis.com/mcp"
    },
    "datacloud_dataproc_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://dataproc-us-east1.googleapis.com/mcp"
    },
    "datacloud_knowledge_catalog_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://dataplex.googleapis.com/mcp"
    },
    "datacloud_spanner_remote": {
      "authProviderType": "google_credentials",
      "headers": {
        "User-Agent": "datacloud.antigravity ide"
      },
      "oauth": {},
      "serverUrl": "https://spanner.googleapis.com/mcp"
    },
    "notebooks": {
      "command": "node",
      "args": [
        "{{ .chezmoi.homeDir }}/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "notebooks-antigravityide"
      ]
    },
    "supabase": {
      "serverUrl": "https://mcp.supabase.com/mcp"
    },
    "trakt": {
      "command": "/opt/homebrew/bin/op",
      "args": [
        "run",
        "--no-masking",
        "--",
        "uvx",
        "--python",
        "3.12",
        "--from",
        "git+https://github.com/wwiens/trakt_mcpserver",
        "trakt-mcp"
      ],
      "env": {
        "TRAKT_CLIENT_ID": "op://Private/Trakt/TRAKT_CLIENT_ID",
        "TRAKT_CLIENT_SECRET": "op://Private/Trakt/TRAKT_CLIENT_SECRET"
      }
    },
    "visualization": {
      "command": "node",
      "args": [
        "{{ .chezmoi.homeDir }}/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "visualization-antigravityide"
      ]
    },
    "X": {
      "command": "/opt/homebrew/bin/op",
      "args": [
        "run",
        "--no-masking",
        "--",
        "npx",
        "-y",
        "@xdevplatform/xurl",
        "mcp",
        "https://api.x.com/mcp"
      ],
      "env": {
        "CLIENT_ID": "op://Private/X API/CLIENT_ID",
        "CLIENT_SECRET": "op://Private/X API/CLIENT_SECRET"
      }
    }
  }
}
