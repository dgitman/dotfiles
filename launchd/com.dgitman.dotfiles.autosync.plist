<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dgitman.dotfiles.autosync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/dgitman/dotfiles/scripts/auto-sync.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/dgitman/dotfiles</string>

  <key>StartInterval</key>
  <integer>86400</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/dgitman/dotfiles/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/dgitman/dotfiles/logs/launchd.err.log</string>
</dict>
</plist>
