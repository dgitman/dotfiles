# 1Password secret references for op run.
# Copy this file to ~/.config/op/dotfiles.env and replace item names/fields as needed.
# Do not put raw secret values in this file.

# OPENAI_API_KEY=op://Private/OpenAI API Key/credential
# GITHUB_TOKEN=op://Private/GitHub Token/credential
# ANTHROPIC_API_KEY=op://Private/Anthropic API Key/credential
# GOOGLE_APPLICATION_CREDENTIALS_JSON=op://Private/Google Service Account/json
